FROM node:22.14.0-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl jq && \
    rm -rf /var/lib/apt/lists/*

# Install OpenClaw (not Claude Code CLI) with global-agent for proxy support
RUN npm install -g openclaw@2026.5.7 global-agent@4.1.3

# Non-root claw user
RUN useradd --create-home --shell /bin/bash claw

# Create OpenClaw config and workspace directories
RUN mkdir -p /home/claw/.openclaw/cron \
    /home/claw/.openclaw/workspace \
    /home/claw/scratch && \
    chown -R claw:claw /home/claw

# Copy configs (mounted :ro at runtime, copied by entrypoint)
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER claw
WORKDIR /home/claw
EXPOSE 18789

ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]
