# BabyClaw secrets — copy to secrets.env and fill in values
# secrets.env is in .gitignore, never committed

# LiteLLM API key (for local gateway — defaults to "ollama")
LITELLM_API_KEY=ollama

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC...

# Telegram chat ID (group or personal chat)
TELEGRAM_CHAT_ID=-123456789

# Telegram user IDs allowed to DM the bot (JSON array, e.g. [123456789])
TELEGRAM_ALLOW_FROM=[]

# User/group ID for the claw container (defaults to 1000:1000)
UID=1000
GID=1000

# Gateway auth token (optional — set for remote access)
GATEWAY_TOKEN=
